{
  "framework": "nextjs",
  "buildCommand": "pnpm run build",
  "installCommand": "pnpm install",
  "devCommand": "pnpm run dev",
  "redirects": [
    {
      "source": "/uploads/desktop-updates",
      "destination": "https://downloads.manacamp.com",
      "permanent": false
    },
    {
      "source": "/uploads/desktop-updates/:path*",
      "destination": "https://downloads.manacamp.com/:path*",
      "permanent": false
    }
  ]
}
